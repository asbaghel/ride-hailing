# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ride_hailing_db
DB_USER=ride_user
DB_PASSWORD=ride_password
DB_POOL_MIN=2
DB_POOL_MAX=10

# Server Configuration
PORT=8000
NODE_ENV=development

# New Relic Configuration
# Get your license key from: https://one.newrelic.com/admin-portal/api-keys/overview
# Copy your INGEST - LICENSE key and set it below
NEW_RELIC_LICENSE_KEY=your_license_key_here
NEW_RELIC_APP_NAME=ride-hailing-api
NEW_RELIC_LOG_LEVEL=info
NEW_RELIC_LOG=stdout
